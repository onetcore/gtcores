@using GSites.Components.Pages
@inherits LayoutComponentBase

<div class="page">
    <Sidebar @rendermode="InteractiveServer" />
    <main>
        <div class="top-row px-2">
            <BreadcrumbOutlet Provider="@MenuDataProvider.DefaultProviderName" />
        </div>

        <article class="content px-2">
            <div class="alert alert-warning">
                当前页面ID： @Context[MenuDataProvider.DefaultProviderName]<br />
                账户管理页面ID： @Context["Account"]
            </div>
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [CascadingParameter]
    public ComponentContext Context { get; set; } = default!;
}