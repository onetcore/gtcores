@implements IDisposable

@inject NavigationManager NavigationManager
@inject User User

<div class="ps-1 navbar">
    <a class="navbar-brand" href="">
        <img class="navbar-avatar"  src="@User.AvatarUrl" />
        <div class="navbar-label">
            <div class="label-main">@(User.DisplayName??User.UserName??"匿名用户")</div>
            <div class="label-secondary">@(User.Email??"login@qq.com")</div>
        </div>
    </a>
</div>

<input type="checkbox" title="导航菜单" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house" aria-hidden="true"></span>
                <span class="text">首页</span>
                <Badge Pill="true" Color="ColorType.Success">12</Badge>
            </NavLink>
            <ul class="nav nav-1 flex-column">
                <li class="nav-item">
                    <NavLink class="nav-link" href="home/overview">
                        <span class="bi bi-speedometer" aria-hidden="true"></span> 概览
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="home/analytics">
                        <span class="bi bi-bar-chart" aria-hidden="true"></span> 分析
                    </NavLink>
                </li>
            </ul>
        </div>

        <div class="nav-item px-2 nav-collapse">
            <NavLink class="nav-link" href="counter">
                <span class="bi bi-alarm" aria-hidden="true"></span> Counter
            </NavLink>
            <ul class="nav nav-1 flex-column">
                <li class="nav-item">
                    <NavLink class="nav-link" href="counter/overview1">
                         Counter概览
                    </NavLink>
                </li>
                <li class="nav-item">
                    <NavLink class="nav-link" href="counter/analytics1">
                         Counter分析
                    </NavLink>
                </li>
            </ul>
        </div>

        <div class="nav-item px-2">
            <NavLink class="nav-link" href="weather">
                <span class="bi bi-list" aria-hidden="true"></span> Weather
            </NavLink>
        </div>

        <div class="nav-item px-2">
            <NavLink class="nav-link" href="auth">
                <span class="bi bi-lock" aria-hidden="true"></span> Auth Required
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-2">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow" aria-hidden="true"></span> 退出登录
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person" aria-hidden="true"></span> 注册
                    </NavLink>
                </div>
                <div class="nav-item px-2">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge" aria-hidden="true"></span> 登录
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
    <nav class="nav flex-column">
        <div class="nav-item px-2">
            <NavLink class="nav-link" href="counter">
                <span class="bi bi-lock" aria-hidden="true"></span> 配置
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

