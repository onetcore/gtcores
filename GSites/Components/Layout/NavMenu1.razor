@implements IDisposable

@inject NavigationManager NavigationManager
@inject User User

<div class="ps-1 navbar">
    <a class="navbar-brand" href="">
        <img class="navbar-avatar" src="@User.AvatarUrl" />
        <div class="navbar-label">
            <div class="label-main">@(User.DisplayName ?? User.UserName ?? "匿名用户")</div>
            <div class="label-secondary">@(User.Email ?? "login@qq.com")</div>
        </div>
    </a>
</div>

<input type="checkbox" title="导航菜单" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <NavMenu Class="px-2 pt-2">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow" aria-hidden="true"></span> 退出登录
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person" aria-hidden="true"></span> 注册
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge" aria-hidden="true"></span> 登录
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </NavMenu>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}