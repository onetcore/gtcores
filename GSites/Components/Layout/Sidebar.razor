@using GSites.Extensions.Themes
@implements IDisposable
@inherits GSites.Extensions.Components.ComponentBase
@inject NavigationManager NavigationManager
@inject User User

<div @attributes="AdditionalAttributes">
    <div class="navbar">
        <a class="navbar-brand" href="Account/Manage">
            <img class="navbar-icon" src="@User.AvatarUrl" />
            <div class="navbar-label">
                <div class="label-main">@(User.DisplayName ?? User.UserName ?? "匿名用户")</div>
                <div class="label-secondary">@(User.Email ?? "login@qq.com")</div>
            </div>
        </a>
    </div>

    <input type="checkbox" title="导航菜单" class="navbar-toggler" />

    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
        <NavMenu class="p-2" DisplayMode="Context.SidebarMode" Current="@Context.Parent" @rendermode="InteractiveServer"></NavMenu>
        <nav class="nav flex-column p-2">
            <AuthorizeView>
                <Authorized>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="Account/Manage">
                            <span class="bi bi-person" aria-hidden="true"></span>
                            <span>@context.User.Identity?.Name</span>
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <form action="Account/Logout" method="post">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <button type="submit" class="nav-link">
                                <span class="bi bi-box-arrow-left" aria-hidden="true"></span>
                                <span>退出登录</span>
                            </button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="Account/Register">
                            <span class="bi bi-person" aria-hidden="true"></span>
                            <span>注册</span>
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="Account/Login">
                            <span class="bi bi-person-badge" aria-hidden="true"></span>
                            <span>登录</span>
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </nav>
    </div>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    protected override ClassName ClassName => "sidebar".AddClass(Context.SidebarMode.ToLower());
}