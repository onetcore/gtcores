@page "/Html/Icons/Bs"

<ul class="row row-cols-3 row-cols-sm-4 row-cols-lg-6 row-cols-xl-8 list-unstyled list">
    @foreach (BsIcon icon in Enum.GetValues<BsIcon>())
    {
        <li class="col mb-4" data-name="0-circle">
            <a class="d-block text-body-emphasis text-decoration-none" href="#">
                <div class="px-3 py-4 mb-2 bg-body-secondary text-center rounded">
                    <Icon Type="icon" />
                </div>
                <div class="name text-muted text-decoration-none text-center pt-1">@icon.GetDescription()</div>
            </a>
        </li>
    }
</ul>