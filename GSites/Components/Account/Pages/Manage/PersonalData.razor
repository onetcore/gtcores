@page "/Account/Manage/PersonalData"

@using Microsoft.AspNetCore.Identity
@using GSites.Extensions

@inject UserManager<User> UserManager
@inject IdentityRedirectManager RedirectManager

<StatusMessage />

<div class="row">
    <div class="col-md-12">
        <p>您的账户包含您提供给我们的个人数据。此页面允许您下载或删除这些数据。</p>
        <div class="alert alert-warning" role="alert">
            <strong>删除这些数据将永久删除您的账户，且此操作无法恢复。</strong>
        </div>
        <form action="Account/Manage/DownloadPersonalData" method="post">
            <AntiforgeryToken />
            <button class="btn btn-primary" type="submit">下载数据</button>
        </form>
        <p class="mt-3 mb-0">
            <a href="Account/Manage/DeletePersonalData" class="btn btn-danger">删除数据</a>
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }
    }
}