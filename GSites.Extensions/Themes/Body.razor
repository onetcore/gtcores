@using GtCores.IdentityCore.Settings
@inject ISettingsManager SettingsManager
@inherits Extensions.ComponentBase

<body @attributes="AdditionalAttributes">
    @ChildContent
</body>

@code {
    /// <summary>
    /// 模板名称。
    /// </summary>
    [Parameter]
    public string? Theme { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Theme))
        {
            var settings = await SettingsManager.GetSettingsAsync<ThemeSettings>();
            Theme = settings?.Name;
        }
        if (!string.IsNullOrWhiteSpace(Theme))
        {
            AdditionalAttributes ??= new();
            AdditionalAttributes["data-bs-theme"] = Theme;
        }
    }
}