<span @attributes="AdditionalAttributes">@ChildContent</span>

@code{
    /// <summary>
    /// 椭圆。
    /// </summary>
    [Parameter]
    public bool Pill { get; set; }

    /// <summary>
    /// 颜色模式。
    /// </summary>
    [Parameter]
    public ColorType Color { get; set; } = ColorType.Primary;

    protected override ClassNameBuilder ClassName => "badge"
        .AddClass($"bg-{Color.ToLower()}")
        .AddClass("rounded-pill", Pill);
}