<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Gd.DouyinPage"
             Title="下载无水印抖音视频"
             Shell.BackgroundColor="#FF0000"
             Shell.TabBarBackgroundColor="#FF0000">
    <ContentPage.Background>
        <LinearGradientBrush EndPoint="0,0.2">
            <GradientStop Color="#FF0000"
                          Offset="0.0"/>
            <GradientStop Color="White"
                          Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>
    <StackLayout>
        <Label Text="请输入抖音视频分享链接"
               FontSize="24"
               Margin="20,20,20,0"
               VerticalOptions="Center"
               HorizontalOptions="Start"/>

        <Border Margin="20,20,20,0"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10">
            <Editor
                x:Name="urlEditor"
                Placeholder="https://www.douyin.com/video/1234567890"
                FontSize="18"
                HeightRequest="100"
                VerticalOptions="CenterAndExpand"
                HorizontalOptions="FillAndExpand"/>
        </Border>
    </StackLayout>
</ContentPage>
