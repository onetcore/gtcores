@using Microsoft.JSInterop
@using System.Reflection.Metadata
@inject NavigationManager NavigationManager
@inject IMenuProviderFactory Factory

<CascadingValue Value="this">
    <ul class="sidebar-nav">
        @foreach (var item in items)
        {
            <NavMenuItem Item="item" />
        }
    </ul>
</CascadingValue>

@code {
    /// <summary>
    /// 菜单提供者名称。
    /// </summary>
    [Parameter]
    public string Name { get; set; } = MenuProvider.DefaultName;

    /// <summary>
    /// 获取当前选中菜单。
    /// </summary>
    public MenuItem? Current { get; set; }

    /// <summary>
    /// 菜单列表。
    /// </summary>
    private IEnumerable<MenuItem> items = Enumerable.Empty<MenuItem>();

    /// <summary>
    /// 初始化菜单数据。
    /// </summary>
    protected override Task OnInitializedAsync()
    {
        var root = Factory.Load(Name);
        if (root == null) return Task.CompletedTask;
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri).AbsolutePath;
        Current = root.Find(uri);
        items = root.OrderByDescending(x => x.Priority).ToList();
        Current ??= items.First().First;
        return Task.CompletedTask;
    }

    /// <summary>
    /// 激活当前菜单。
    /// </summary>
    /// <param name="item">当前菜单项。</param>
    public void NavigateTo(MenuItem item)
    {
        Current = item;
        StateHasChanged();
    }

    /// <summary>
    /// 判断当前菜单是否激活。
    /// </summary>
    /// <param name="uniqueId">当前菜单唯一Id。</param>
    /// <returns>返回判断结果。</returns>
    public bool IsCurrent(string uniqueId)
    {
        var current = Current;
        while (current?.IsRoot == false)
        {
            if (current.UniqueId == uniqueId)
                return true;
            current = current.Parent;
        }

        return false;
    }

}