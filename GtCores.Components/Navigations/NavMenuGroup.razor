@if (Item.Any())
{
    <ul id="@Item.UniqueId" class="@className" data-bs-parent=".sidebar">
        @foreach (var item in Item)
        {
            <NavMenuItem Item="item" />
        }
    </ul>
}
@code {
    /// <summary>
    /// 菜单项目列表。
    /// </summary>
    [Parameter]
    public MenuItem Item { get; set; } = null!;

    /// <summary>
    /// 是否当前菜单。
    /// </summary>
    [Parameter]
    public bool IsCurrent { get; set; }

    private string className = "sidebar-dropdown list-unstyled collapse";
    protected override void OnParametersSet()
    {
        if (IsCurrent)
        {
            className += " show";
        }
    }
}